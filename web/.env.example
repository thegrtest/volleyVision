# ─────────────────────────────────────────────────────────────────────────────
# NetSight web — environment variables.
# Copy to .env.local and fill in:   cp .env.example .env.local
# The app runs WITHOUT any of these (it degrades gracefully); they unlock the
# database and tune metadata. .env.local is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string — the only thing the database needs.
#   Local:    postgres://postgres:postgres@localhost:5432/netsight
#   Neon:     postgresql://<user>:<pwd>@<endpoint>.neon.tech/<db>?sslmode=require
#   Supabase: postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Leave empty to run without a DB (/api/health reports "unconfigured").
# NOTE: migrations need a DIRECT/session connection, not a transaction pooler —
# see docs/BACKEND.md.
DATABASE_URL=

# Public base URL of the site, used for SEO / OpenGraph metadata (src/app/layout.tsx).
# Defaults to https://netsight.org when unset.
NEXT_PUBLIC_SITE_URL=

# URL of the Python CV worker that processes game video. Not wired into the app
# code yet (see ../cv/ and docs/ARCHITECTURE.md) — reserved for a later phase.
# CV_WORKER_URL=
